[build]
    time_start: build
    run: gcc sal.c util.c set/set.c os/win.c -o sal -lssl -lcrypto -Wno-format-truncation -Wno-stringop-truncation -g
    time_end: build
    end

[cleanup]
    #run: rm sal
    run: rm -rf C:\teste
    end


[teste]
    goto: build
    silent: 0
    time_start: teste

    run: .\sal
    run: .\sal -new porra

    new_input: s
    task: .\sal -info porra

    run: .\sal -view porra

    time_end: teste
    silent: 1
    goto: cleanup

    end


[main]
    goto: build

    silent: 0
    run: .\sal
    silent: 1

    #goto: cleanup
    end 
